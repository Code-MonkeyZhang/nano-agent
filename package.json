{
  "name": "nano-agent",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "nano-agent": "dist/src/index.js"
  },
  "private": true,
  "scripts": {
    "build": "bun build ./src/index.ts --compile --outfile ./dist/nano-agent",
    "build:bundle": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:vitest": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --quiet",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "preflight": "bun run build && bun test && bun run lint",
    "server": "bun run src/server/standalone.ts",
    "prepare": "bun run scripts/prepare-cloudflared.mjs",
    "prepare:all": "bun run scripts/prepare-cloudflared.mjs --platform all"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.10.2",
    "@types/open": "^6.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@mariozechner/pi-ai": "^0.57.1",
    "@modelcontextprotocol/sdk": "^1.1.0",
    "chalk": "^5.6.2",
    "cloudflared": "^0.7.1",
    "commander": "^14.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "ink": "npm:@jrichman/ink@^6.4.10",
    "jimp": "^1.6.0",
    "lowlight": "^3.3.0",
    "multer": "^2.1.1",
    "open": "^11.0.0",
    "openai": "^6.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "string-width": "^8.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
